---
import Base from '../../layouts/Base.astro';
import { PHASES, CHAPTERS } from '../../data/circuitos.js';
---

<Base
  title="Engenharia Elétrica · Análise de Circuitos — Engenharia·Hub"
  description="Trilha interativa de Análise de Circuitos Elétricos em 16 capítulos — módulo de Engenharia Elétrica."
>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">
        <span class="dot" aria-hidden="true"></span>
        <span>ENGENHARIA·HUB<small>engenharia elétrica</small></span>
      </a>
      <div class="right">
        <span class="prog-num" id="progText">0 / 16</span>
        <div class="prog-track" aria-hidden="true"><div class="prog-fill" id="progFill"></div></div>
        <button class="theme-btn" id="themeBtn" type="button" aria-label="Alternar tema claro/escuro">tema</button>
      </div>
    </div>
  </div>

  <header class="hero">
    <div class="wrap">
      <a class="crumb" href="/">← Hub de Engenharias</a>
      <div class="scope">
        <canvas id="scopeCanvas" aria-hidden="true"></canvas>
        <div class="scope-overlay">
          <div class="scope-top">
            <span class="scope-badge"><span class="ch-tag">CH1</span> · corrente · CC → CA</span>
            <span class="scope-badge"><span class="ch-tag amber">CH2</span> · tensão · resposta</span>
          </div>
          <div class="scope-readout">t/div 2ms &nbsp;·&nbsp; v/div 500mV &nbsp;·&nbsp; trig ↑ &nbsp;·&nbsp; run</div>
        </div>
      </div>

      <p class="eyebrow" style="margin-top:28px">Engenharia Elétrica · Módulo 01 — Análise de Circuitos</p>
      <h1 class="title">Todo circuito conta uma história. <span class="g">Aprenda a lê-la.</span></h1>
      <p class="lede">
        Dezesseis capítulos que te levam da carga elétrica ao amplificador operacional — os mesmos
        fundamentos por trás do seu celular, do carro, da rede de energia e de cada sensor do planeta.
        Cada capítulo abre uma aula com teoria, ilustração interativa e um desafio.
      </p>

      <div class="hero-meta">
        <div class="stat"><span class="n">16</span><span class="l">capítulos</span></div>
        <div class="stat"><span class="n">7</span><span class="l">fases da trilha</span></div>
        <div class="stat"><span class="n">70+</span><span class="l">tópicos</span></div>
        <div class="stat"><span class="n">1</span><span class="l">base que sustenta tudo</span></div>
      </div>

      <p class="src-note">
        Conteúdo baseado na <em>Sebenta Multimédia de Análise de Circuitos Eléctricos</em> do Prof. Victor Dias (IST),
        material de referência em Teoria de Circuitos — <a href="https://www.ufrgs.br/eng04030/Aulas/teoria/capa.htm" target="_blank" rel="noopener">fonte original</a>.
      </p>
    </div>
  </header>

  <section class="block">
    <div class="wrap">
      <p class="eyebrow">o mapa</p>
      <div class="sec-head"><h2>A trilha em 7 fases</h2></div>
      <p class="sec-sub">
        Circuitos se aprende em ordem: cada fase abre a porta da seguinte. A cor esquenta conforme os
        circuitos ganham energia e dinâmica — do estático (corrente contínua) ao ativo (amplificação).
      </p>
      <div class="rail">
        {PHASES.map((p) => (
          <div class="rail-node" style={`--pc: var(--p${p.n})`}>
            <div class="rail-dot">{p.n}</div>
            <div class="rail-label"><b>{p.title}</b>{p.tag}</div>
            <div class="rail-cap">{p.caps.length > 1 ? `Cap ${p.caps[0]}–${p.caps[p.caps.length - 1]}` : `Cap ${p.caps[0]}`}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block" style="padding-top:0">
    <div class="wrap">
      {PHASES.map((p) => (
        <div class="phase" style={`--pc: var(--p${p.n})`}>
          <div class="phase-head">
            <span class="phase-idx">{p.idx}</span>
            <div><p class="phase-title">{p.title}</p><p class="phase-tagline">{p.tag}</p></div>
            <span class="phase-count" data-phase={p.n} data-total={p.caps.length}>0/{p.caps.length}</span>
          </div>
          <div class="cards">
            {p.caps.map((num) => {
              const c = CHAPTERS[num];
              const nn = String(num).padStart(2, "0");
              return (
                <a class="card" href={`/circuitos/${num}`} data-ch={num} aria-label={`Capítulo ${num}: ${c.title}`}>
                  <span class="card-check" aria-hidden="true"></span>
                  <div class="card-top">
                    <span class="card-num">{nn}</span>
                    <h3>{c.title}</h3>
                  </div>
                  <p class="learn">{c.learn}</p>
                  <div class="app"><span class="app-l">onde isso vive</span>{c.app}</div>
                  <div class="card-foot">
                    <span class="formula">{c.f}</span>
                    <span class="prereq">{c.req ? `requer ${c.req}` : "ponto de partida"}</span>
                    <span class="go">{c.ready ? "abrir aula" : "prévia"} →</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <footer class="foot">
    <div class="wrap">
      <span>Engenharia·Hub — feito para quem está começando.</span>
      <span class="mono">elétrica / módulo 01 · v1</span>
    </div>
  </footer>

  <style is:global>
    .crumb { display: inline-block; margin-bottom: 22px; font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: .06em; color: var(--text-dim); text-decoration: none; }
    .crumb:hover { color: var(--text); }
    .hero { position: relative; padding: clamp(30px, 6vw, 64px) 0 clamp(30px,5vw,60px); }
    .scope { position: relative; border-radius: 16px; overflow: hidden; border: 1px solid var(--line);
      background: linear-gradient(180deg, color-mix(in oklab, var(--bg-2), var(--trace-1) 4%), var(--bg-2)); box-shadow: var(--shadow); }
    .scope canvas { display: block; width: 100%; height: 320px; }
    .scope-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 20px 22px; pointer-events: none; }
    .scope-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .scope-badge { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-dim); border: 1px solid var(--line); border-radius: 6px; padding: 4px 8px; background: color-mix(in oklab, var(--bg-2), transparent 25%); }
    .ch-tag { color: var(--trace-1); } .ch-tag.amber { color: var(--trace-2); }
    .scope-readout { font-family: var(--font-mono); font-size: 0.66rem; color: var(--text-faint); letter-spacing: .08em; }
    h1.title { font-size: clamp(2.2rem, 6.4vw, 4.4rem); line-height: 1.02; letter-spacing: -0.03em; font-weight: 700; margin: 22px 0 0; text-wrap: balance; max-width: 15ch; }
    h1.title .g { background: linear-gradient(100deg, var(--trace-1), var(--trace-2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .lede { margin: 20px 0 0; font-size: clamp(1.02rem, 2vw, 1.24rem); color: var(--text-dim); max-width: 62ch; text-wrap: pretty; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 28px; }
    .hero-meta .stat { display: flex; flex-direction: column; }
    .hero-meta .n { font-family: var(--font-mono); font-size: 1.5rem; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
    .hero-meta .l { font-size: 0.74rem; color: var(--text-faint); letter-spacing: .04em; }
    .src-note { margin-top: 26px; font-size: 0.82rem; color: var(--text-faint); }
    .src-note a { color: var(--text-dim); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--line); }

    section.block { padding: clamp(34px, 6vw, 68px) 0; }
    .sec-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 8px; }
    .sec-head h2 { font-size: clamp(1.5rem, 3.4vw, 2.2rem); letter-spacing: -0.02em; margin: 0; font-weight: 700; }
    .sec-sub { color: var(--text-dim); max-width: 66ch; margin: 6px 0 0; }

    .rail { display: grid; grid-template-columns: repeat(7, 1fr); gap: 10px; margin-top: 30px; position: relative; }
    .rail::before { content:""; position:absolute; top: 15px; left: 4%; right: 4%; height: 2px; background: linear-gradient(90deg, var(--p1), var(--p4), var(--p7)); opacity: .5; border-radius: 2px; }
    .rail-node { display: flex; flex-direction: column; align-items: center; gap: 10px; text-align: center; position: relative; }
    .rail-dot { width: 32px; height: 32px; border-radius: 50%; background: var(--bg); border: 2px solid var(--pc); display: grid; place-items: center; font-family: var(--font-mono); font-weight: 600; font-size: .82rem; color: var(--pc); z-index: 1; box-shadow: 0 0 0 4px var(--bg); }
    .rail-label { font-size: 0.72rem; color: var(--text-dim); line-height: 1.3; }
    .rail-label b { display:block; color: var(--text); font-size: 0.78rem; }
    .rail-cap { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-faint); }
    @media (max-width: 720px) { .rail { grid-template-columns: repeat(2, 1fr); gap: 18px; } .rail::before { display: none; } }

    .phase { padding-top: 30px; border-top: 1px solid var(--line-2); margin-top: 30px; }
    .phase-head { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; flex-wrap: wrap; }
    .phase-idx { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--bg); background: var(--pc); padding: 5px 10px; border-radius: 6px; font-weight: 600; }
    .phase-title { font-size: clamp(1.15rem, 2.6vw, 1.5rem); font-weight: 700; letter-spacing: -0.01em; margin: 0; }
    .phase-tagline { color: var(--text-dim); font-size: 0.92rem; margin: 0; }
    .phase-count { margin-left: auto; font-family: var(--font-mono); font-size: 0.74rem; color: var(--text-faint); font-variant-numeric: tabular-nums; }

    .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
    .card { position: relative; display: block; text-decoration: none; color: inherit; background: var(--bg-2); border: 1px solid var(--line); border-radius: 13px; padding: 18px 18px 16px; overflow: hidden; transition: transform .25s cubic-bezier(.2,.8,.2,1), border-color .25s, box-shadow .25s; }
    .card::before { content:""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--pc); opacity: .85; }
    .card:hover { transform: translateY(-3px); border-color: color-mix(in oklab, var(--pc), var(--line) 45%); box-shadow: var(--shadow); }
    .card:hover .go { color: var(--pc); }
    .card.done { border-color: color-mix(in oklab, var(--good), var(--line) 55%); }
    .card.done::before { background: var(--good); }
    .card-check { position: absolute; top: 14px; right: 14px; width: 20px; height: 20px; border-radius: 50%; border: 1.5px solid var(--line); display: grid; place-items: center; opacity: 0; transition: opacity .2s; }
    .card.done .card-check { opacity: 1; border-color: var(--good); background: var(--good); }
    .card.done .card-check::after { content: "✓"; color: var(--bg); font-size: 12px; font-weight: 700; line-height: 1; }
    .card-top { display: flex; align-items: flex-start; gap: 12px; padding-right: 26px; }
    .card-num { font-family: var(--font-mono); font-size: 1.85rem; font-weight: 700; line-height: 1; color: var(--pc); font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
    .card h3 { font-size: 1.02rem; margin: 2px 0 0; letter-spacing: -0.01em; line-height: 1.25; flex: 1; }
    .card .learn { color: var(--text-dim); font-size: 0.9rem; margin: 12px 0 0; }
    .app { margin-top: 13px; padding: 10px 12px; border-radius: 9px; background: color-mix(in oklab, var(--pc), transparent 90%); border: 1px solid color-mix(in oklab, var(--pc), transparent 78%); font-size: 0.85rem; }
    .app .app-l { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: .16em; text-transform: uppercase; color: var(--pc); display: block; margin-bottom: 3px; }
    .card-foot { display: flex; align-items: center; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
    .formula { font-family: var(--font-mono); font-size: 0.82rem; color: var(--text); background: var(--bg-3); border: 1px solid var(--line-2); border-radius: 7px; padding: 4px 9px; white-space: nowrap; overflow-x: auto; max-width: 100%; }
    .prereq { font-family: var(--font-mono); font-size: 0.66rem; color: var(--text-faint); letter-spacing: .04em; }
    .go { margin-left: auto; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: .06em; color: var(--text-faint); transition: color .2s; white-space: nowrap; }

    @media (prefers-reduced-motion: reduce) { .card { transition: none; } }
  </style>

  <script is:inline>
    (function () {
      "use strict";
      var STORE = "enghub_circuitos_v1";
      var done = {};
      try { done = JSON.parse(localStorage.getItem(STORE) || "{}") || {}; } catch (e) { done = {}; }

      var total = 16, count = 0;
      for (var k in done) { if (done[k]) count++; }
      document.querySelectorAll(".card").forEach(function (c) {
        if (done[c.getAttribute("data-ch")]) c.classList.add("done");
      });
      var fill = document.getElementById("progFill");
      var ptext = document.getElementById("progText");
      if (fill) fill.style.width = (count / total * 100) + "%";
      if (ptext) ptext.textContent = count + " / " + total;
      document.querySelectorAll("[data-phase]").forEach(function (badge) {
        var t = parseInt(badge.getAttribute("data-total"), 10), c = 0;
        badge.closest(".phase").querySelectorAll(".card").forEach(function (card) {
          if (done[card.getAttribute("data-ch")]) c++;
        });
        badge.textContent = c + "/" + t;
        badge.style.color = (c === t && t > 0) ? "var(--good)" : "var(--text-faint)";
      });

      var canvas = document.getElementById("scopeCanvas");
      if (!canvas) return;
      var ctx = canvas.getContext("2d");
      var root = document.documentElement;
      var W = 0, H = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
      var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      function css(v) { return getComputedStyle(root).getPropertyValue(v).trim(); }
      function resize() { var r = canvas.getBoundingClientRect(); W = r.width; H = r.height; canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr); ctx.setTransform(dpr, 0, 0, dpr, 0, 0); }
      function drawGrid() {
        var g = css("--grid"), gs = css("--grid-strong"), step = W / 20; ctx.lineWidth = 1;
        for (var x = 0; x <= W; x += step) { ctx.strokeStyle = (Math.round(x / step) % 5 === 0) ? gs : g; ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
        var ys = H / 8;
        for (var y = 0; y <= H; y += ys) { ctx.strokeStyle = (Math.round(y / ys) % 4 === 0) ? gs : g; ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }
      }
      function signal(u, t) {
        var y;
        if (u < 0.16) { y = 0.0; }
        else if (u < 0.34) { var s = (u - 0.16) / 0.18; y = 0.55 * (1 - Math.exp(-s * 6)); }
        else if (u < 0.55) { var d = (u - 0.34) / 0.21; y = 0.6 * Math.exp(-d * 3) * Math.cos(d * 22 - t * 2); }
        else { var f = (u - 0.55) / 0.45; var freq = 6 + f * 22; y = (0.32 + 0.28 * f) * Math.sin(f * freq - t * 2.4); }
        return y;
      }
      function trace(offset, colorVar, amp, phase, t) {
        ctx.strokeStyle = css(colorVar); ctx.lineWidth = 2; ctx.lineJoin = "round"; ctx.shadowColor = css(colorVar); ctx.shadowBlur = 9; ctx.beginPath();
        var mid = H * 0.5 + offset, N = Math.max(120, Math.floor(W));
        for (var i = 0; i <= N; i++) { var u = i / N; var y = signal(u, t + phase) * amp; var px = u * W; var py = mid - y * (H * 0.34); if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py); }
        ctx.stroke(); ctx.shadowBlur = 0;
      }
      var start = null, raf = null;
      function frame(ts) { if (start === null) start = ts; var t = (ts - start) / 1000; ctx.clearRect(0, 0, W, H); drawGrid(); trace(6, "--trace-2", 0.9, 0.5, t * 0.7); trace(-4, "--trace-1", 1.0, 0.0, t); raf = requestAnimationFrame(frame); }
      function drawStatic() { ctx.clearRect(0, 0, W, H); drawGrid(); trace(6, "--trace-2", 0.9, 0.5, 0.6); trace(-4, "--trace-1", 1.0, 0.0, 0.0); }
      function boot() { resize(); if (reduce) { drawStatic(); } else { if (raf) cancelAnimationFrame(raf); start = null; raf = requestAnimationFrame(frame); } }
      boot();
      var rt;
      window.addEventListener("resize", function () { clearTimeout(rt); rt = setTimeout(function () { dpr = Math.min(window.devicePixelRatio || 1, 2); boot(); }, 160); });
    })();
  </script>
</Base>
