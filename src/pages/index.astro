---
import Base from '../layouts/Base.astro';
import { DISCIPLINES, ICONS } from '../data/disciplines.js';

const live = DISCIPLINES.filter((d) => d.status === 'live').length;
---

<Base
  title="Engenharia·Hub — painel de engenharias"
  description="Painel de Conhecimento de Engenharia. Trilhas visuais e interativas por disciplina: Elétrica, Eletrônica, Civil, Segurança e mais."
>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">
        <span class="dot" aria-hidden="true"></span>
        <span>ENGENHARIA·HUB<small>painel de conhecimento</small></span>
      </a>
      <div class="right">
        <span class="sys-status"><span class="led-mini" aria-hidden="true"></span> SYS ONLINE</span>
        <span class="prog-num">{live}/{DISCIPLINES.length} ativas</span>
        <button class="theme-btn" id="themeBtn" type="button" aria-label="Alternar tema claro/escuro">tema</button>
      </div>
    </div>
  </div>

  <header class="home-hero">
    <div class="grid-bg" aria-hidden="true"><div class="scan"></div></div>
    <div class="wrap">
      <p class="eyebrow">// sistema de aprendizado em engenharia</p>
      <h1>Painel de <span class="g">Engenharias.</span></h1>
      <p class="lede">
        Selecione uma área para entrar. Cada engenharia é uma trilha viva — o melhor material de
        estudo transformado em jornada visual, com aplicações reais, ilustrações interativas e desafios.
      </p>
      <div class="hero-line" aria-hidden="true">
        <span>{DISCIPLINES.length} áreas mapeadas</span>
        <span class="sep">·</span>
        <span>{live} trilha ativa</span>
        <span class="sep">·</span>
        <span>expansão contínua</span>
      </div>
    </div>
  </header>

  <main class="block">
    <div class="wrap">
      <div class="panel-grid">
        {DISCIPLINES.map((d, i) => {
          const sys = `SYS-${String(i + 1).padStart(2, '0')}`;
          const inner = (
            <>
              <span class="corner tl" aria-hidden="true"></span>
              <span class="corner br" aria-hidden="true"></span>

              <div class="p-head">
                <span class="p-code">{sys} · {d.code}</span>
                <span class={`p-status ${d.status}`}>
                  <span class="led" aria-hidden="true"></span>
                  {d.status === 'live' ? 'ONLINE' : 'STANDBY'}
                </span>
              </div>

              <div class="p-icon" set:html={`<svg viewBox="0 0 32 32" width="38" height="38" aria-hidden="true">${ICONS[d.icon]}</svg>`}></div>

              <h2 class="p-name">{d.name}</h2>
              <p class="p-tag">{d.tag}</p>

              {d.status === 'live' && d.progressTotal ? (
                <div class="p-prog" data-key={d.progressKey} data-total={d.progressTotal}>
                  <div class="segs">
                    {Array.from({ length: d.progressTotal }).map(() => <span class="seg"></span>)}
                  </div>
                  <span class="p-prog-num">00/{d.progressTotal}</span>
                </div>
              ) : (
                <div class="p-prog placeholder"><span class="p-standby">módulo em desenvolvimento</span></div>
              )}

              <div class="p-foot">
                <span class="p-meta">{d.meta}</span>
                <span class="p-go">{d.status === 'live' ? 'acessar →' : 'aguarde'}</span>
              </div>
            </>
          );
          return d.href
            ? <a class="panel live" href={d.href} style={`--acc: ${d.accent}`} aria-label={`Acessar ${d.name}`}>{inner}</a>
            : <div class="panel soon" style={`--acc: ${d.accent}`} aria-disabled="true">{inner}</div>;
        })}
      </div>
    </div>
  </main>

  <footer class="foot">
    <div class="wrap">
      <span>Engenharia·Hub — feito para quem está começando.</span>
      <span class="mono">painel · v1</span>
    </div>
  </footer>

  <style is:global>
    .sys-status { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: .12em; color: var(--text-dim); }
    .led-mini { width: 7px; height: 7px; border-radius: 50%; background: var(--good); box-shadow: 0 0 8px var(--good); animation: blink 2.4s ease-in-out infinite; }

    .home-hero { position: relative; padding: clamp(52px, 11vw, 116px) 0 clamp(28px, 6vw, 52px); overflow: hidden; }
    .grid-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden;
      background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(130% 100% at 15% -10%, #000 42%, transparent 80%);
      -webkit-mask-image: radial-gradient(130% 100% at 15% -10%, #000 42%, transparent 80%); }
    .scan { position: absolute; left: 0; right: 0; height: 42%; top: 0;
      background: linear-gradient(180deg, transparent, color-mix(in oklab, var(--trace-1), transparent 90%) 55%, transparent);
      animation: scan 7s linear infinite; }
    .home-hero .wrap { position: relative; z-index: 1; }
    .home-hero .eyebrow { color: var(--trace-1); }
    .home-hero h1 { font-size: clamp(2.6rem, 8vw, 5rem); line-height: 1; letter-spacing: -0.035em; font-weight: 700; margin: 16px 0 0; text-wrap: balance; }
    .home-hero h1 .g { background: linear-gradient(100deg, var(--trace-1), var(--trace-2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .home-hero .lede { margin: 20px 0 0; font-size: clamp(1.05rem, 2.2vw, 1.28rem); color: var(--text-dim); max-width: 60ch; text-wrap: pretty; }
    .hero-line { margin-top: 22px; display: flex; flex-wrap: wrap; gap: 12px; font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: .06em; color: var(--text-faint); }
    .hero-line .sep { opacity: .5; }

    .block { padding: clamp(18px, 3vw, 32px) 0 clamp(44px, 8vw, 84px); }
    .panel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    @media (max-width: 900px) { .panel-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .panel-grid { grid-template-columns: 1fr; } }

    .panel { position: relative; display: flex; flex-direction: column; background: linear-gradient(160deg, color-mix(in oklab, var(--bg-2), var(--acc) 5%), var(--bg-2)); border: 1px solid var(--line); border-radius: 14px; padding: 20px 20px 16px; text-decoration: none; color: inherit; overflow: hidden; min-height: 258px; transition: transform .28s cubic-bezier(.2,.8,.2,1), border-color .28s, box-shadow .28s; }
    .panel::after { content: ""; position: absolute; inset: 0; background: radial-gradient(120% 80% at 50% -20%, color-mix(in oklab, var(--acc), transparent 82%), transparent 70%); opacity: 0; transition: opacity .3s; pointer-events: none; }
    .panel .corner { position: absolute; width: 13px; height: 13px; border: 2px solid var(--acc); opacity: .45; transition: opacity .28s; }
    .panel .corner.tl { top: 9px; left: 9px; border-right: 0; border-bottom: 0; border-top-left-radius: 3px; }
    .panel .corner.br { bottom: 9px; right: 9px; border-left: 0; border-top: 0; border-bottom-right-radius: 3px; }
    .panel.live { cursor: pointer; }
    .panel.live:hover { transform: translateY(-5px); border-color: color-mix(in oklab, var(--acc), var(--line) 30%); box-shadow: 0 22px 50px -26px color-mix(in oklab, var(--acc), #000 30%); }
    .panel.live:hover::after { opacity: 1; }
    .panel.live:hover .corner { opacity: 1; }
    .panel.live:hover .p-go { color: var(--acc); }
    .panel.live:hover .p-icon { color: var(--acc); transform: translateY(-2px); }
    .panel.soon { opacity: .6; }

    .p-head { display: flex; align-items: center; justify-content: space-between; }
    .p-code { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: .14em; color: var(--text-faint); }
    .p-status { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: .14em; }
    .p-status.live { color: var(--acc); }
    .p-status.soon { color: var(--text-faint); }
    .led { width: 8px; height: 8px; border-radius: 50%; background: var(--acc); box-shadow: 0 0 9px var(--acc); position: relative; }
    .p-status.live .led { animation: blink 2s ease-in-out infinite; }
    .p-status.soon .led { background: var(--text-faint); box-shadow: none; }

    .p-icon { color: var(--acc); margin: 20px 0 0; display: inline-flex; transition: transform .28s, color .28s; }
    .panel.soon .p-icon { color: var(--text-faint); }
    .p-name { font-size: 1.24rem; font-weight: 700; letter-spacing: -0.02em; margin: 14px 0 0; }
    .p-tag { color: var(--text-dim); font-size: 0.9rem; margin: 7px 0 0; flex: 1; }

    .p-prog { display: flex; align-items: center; gap: 10px; margin: 16px 0 0; }
    .p-prog.placeholder { opacity: .8; }
    .p-standby { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: .1em; color: var(--text-faint); text-transform: uppercase; }
    .segs { display: flex; gap: 3px; flex: 1; }
    .seg { flex: 1; height: 7px; border-radius: 2px; background: var(--line); transition: background .3s, box-shadow .3s; }
    .seg.on { background: var(--acc); box-shadow: 0 0 7px color-mix(in oklab, var(--acc), transparent 40%); }
    .p-prog-num { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); font-variant-numeric: tabular-nums; }

    .p-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; padding-top: 13px; border-top: 1px solid var(--line-2); }
    .p-meta { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: .04em; color: var(--text-faint); }
    .p-go { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: .08em; color: var(--text-dim); transition: color .2s; text-transform: uppercase; }

    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: .35; } }
    @keyframes scan { 0% { transform: translateY(-110%); } 100% { transform: translateY(340%); } }
    @media (prefers-reduced-motion: reduce) {
      .scan { display: none; }
      .led-mini, .p-status.live .led { animation: none; }
      .panel.live:hover { transform: none; }
      .panel.live:hover .p-icon { transform: none; }
    }
  </style>

  <script is:inline>
    (function () {
      document.querySelectorAll(".p-prog").forEach(function (el) {
        var key = el.getAttribute("data-key");
        if (!key) return;
        var total = parseInt(el.getAttribute("data-total"), 10) || 1;
        var done = {};
        try { done = JSON.parse(localStorage.getItem(key) || "{}") || {}; } catch (e) {}
        var count = 0; for (var k in done) { if (done[k]) count++; }
        var segs = el.querySelectorAll(".seg");
        for (var i = 0; i < segs.length && i < count; i++) segs[i].classList.add("on");
        var num = el.querySelector(".p-prog-num");
        if (num) num.textContent = String(count).padStart(2, "0") + "/" + total;
      });
    })();
  </script>
</Base>
