---
import Base from '../layouts/Base.astro';
import { DISCIPLINES, ICONS } from '../data/disciplines.js';

const live = DISCIPLINES.filter((d) => d.status === 'live').length;
---

<Base
  title="Engenharia·Hub — escolha o seu caminho"
  description="Hub de Conhecimento de Engenharia. Trilhas visuais e interativas por disciplina: Elétrica, Eletrônica, Civil, Segurança e mais."
>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">
        <span class="dot" aria-hidden="true"></span>
        <span>ENGENHARIA·HUB<small>hub de conhecimento</small></span>
      </a>
      <div class="right">
        <span class="prog-num">{live} de {DISCIPLINES.length} trilhas no ar</span>
        <button class="theme-btn" id="themeBtn" type="button" aria-label="Alternar tema claro/escuro">tema</button>
      </div>
    </div>
  </div>

  <header class="home-hero">
    <div class="grid-bg" aria-hidden="true"></div>
    <div class="wrap">
      <p class="eyebrow">Hub de Conhecimento de Engenharia</p>
      <h1>Escolha o seu <span class="g">caminho.</span></h1>
      <p class="lede">
        Cada engenharia é uma trilha: o melhor material de estudo transformado em jornada visual —
        com aplicações do mundo real, mapa de pré-requisitos, ilustrações interativas e desafios.
        Comece por onde a sua curiosidade puxar.
      </p>
    </div>
  </header>

  <main class="block">
    <div class="wrap">
      <div class="disc-grid">
        {DISCIPLINES.map((d) => {
          const inner = (
            <>
              <div class="disc-top">
                <span class="disc-icon" set:html={`<svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true">${ICONS[d.icon]}</svg>`}></span>
                {d.status === 'live'
                  ? <span class="disc-badge on">no ar</span>
                  : <span class="disc-badge soon">em breve</span>}
              </div>
              <h2 class="disc-name">{d.name}</h2>
              <p class="disc-tag">{d.tag}</p>
              {d.status === 'live' && d.progressTotal ? (
                <div class="disc-prog" data-key={d.progressKey} data-total={d.progressTotal}>
                  <div class="disc-prog-bar"><span></span></div>
                  <span class="disc-prog-num">0/{d.progressTotal}</span>
                </div>
              ) : null}
              <div class="disc-foot">
                <span class="disc-meta">{d.meta}</span>
                {d.status === 'live' ? <span class="disc-go">entrar →</span> : null}
              </div>
            </>
          );
          return d.href
            ? <a class="disc-card live" href={d.href} style={`--acc: ${d.accent}`} aria-label={`Entrar em ${d.name}`}>{inner}</a>
            : <div class="disc-card soon" style={`--acc: ${d.accent}`} aria-disabled="true">{inner}</div>;
        })}
      </div>

      <p class="hint">
        As trilhas marcadas como <b>em breve</b> estão a caminho. A de <b>Engenharia Elétrica</b> já está
        completa em estrutura — 16 capítulos, com o primeiro totalmente interativo.
      </p>
    </div>
  </main>

  <footer class="foot">
    <div class="wrap">
      <span>Engenharia·Hub — feito para quem está começando.</span>
      <span class="mono">hub · v1</span>
    </div>
  </footer>

  <style is:global>
    .home-hero { position: relative; padding: clamp(56px, 12vw, 128px) 0 clamp(30px, 6vw, 56px); overflow: hidden; }
    .grid-bg { position: absolute; inset: 0; z-index: 0;
      background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 46px 46px; mask-image: radial-gradient(120% 90% at 20% 0%, #000 40%, transparent 78%);
      -webkit-mask-image: radial-gradient(120% 90% at 20% 0%, #000 40%, transparent 78%); }
    .home-hero .wrap { position: relative; z-index: 1; }
    .home-hero h1 { font-size: clamp(2.6rem, 8vw, 5rem); line-height: 1; letter-spacing: -0.035em; font-weight: 700; margin: 18px 0 0; text-wrap: balance; }
    .home-hero h1 .g { background: linear-gradient(100deg, var(--trace-1), var(--trace-2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .home-hero .lede { margin: 22px 0 0; font-size: clamp(1.05rem, 2.2vw, 1.3rem); color: var(--text-dim); max-width: 62ch; text-wrap: pretty; }

    .block { padding: clamp(20px, 4vw, 40px) 0 clamp(40px, 8vw, 80px); }
    .disc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
    .disc-card { position: relative; display: flex; flex-direction: column; gap: 0; background: var(--bg-2); border: 1px solid var(--line); border-radius: 16px; padding: 22px 22px 18px; text-decoration: none; color: inherit; overflow: hidden; min-height: 210px; transition: transform .25s cubic-bezier(.2,.8,.2,1), border-color .25s, box-shadow .25s; }
    .disc-card::before { content:""; position: absolute; inset: 0 0 auto 0; height: 3px; background: var(--acc); opacity: .9; }
    .disc-card.live { cursor: pointer; }
    .disc-card.live:hover { transform: translateY(-4px); border-color: color-mix(in oklab, var(--acc), var(--line) 40%); box-shadow: var(--shadow); }
    .disc-card.live:hover .disc-go { color: var(--acc); }
    .disc-card.soon { opacity: .62; }
    .disc-top { display: flex; align-items: center; justify-content: space-between; }
    .disc-icon { color: var(--acc); display: inline-flex; }
    .disc-badge { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: .14em; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; }
    .disc-badge.on { background: var(--acc); color: #071019; font-weight: 700; }
    .disc-badge.soon { border: 1px solid var(--line); color: var(--text-faint); }
    .disc-name { font-size: 1.28rem; font-weight: 700; letter-spacing: -0.02em; margin: 18px 0 0; }
    .disc-tag { color: var(--text-dim); font-size: 0.93rem; margin: 8px 0 0; flex: 1; }
    .disc-prog { display: flex; align-items: center; gap: 10px; margin: 16px 0 0; }
    .disc-prog-bar { flex: 1; height: 6px; border-radius: 99px; background: var(--line); overflow: hidden; }
    .disc-prog-bar span { display: block; height: 100%; width: 0%; border-radius: 99px; background: var(--acc); transition: width .5s cubic-bezier(.2,.8,.2,1); }
    .disc-prog-num { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); font-variant-numeric: tabular-nums; }
    .disc-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; }
    .disc-meta { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: .04em; color: var(--text-faint); }
    .disc-go { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: .06em; color: var(--text-dim); transition: color .2s; }
    .hint { margin: 30px 0 0; font-size: 0.88rem; color: var(--text-faint); max-width: 68ch; }
    .hint b { color: var(--text-dim); font-weight: 600; }

    @media (prefers-reduced-motion: reduce) { .disc-card.live:hover { transform: none; } .disc-prog-bar span { transition: none; } }
  </style>

  <script is:inline>
    (function () {
      document.querySelectorAll(".disc-prog").forEach(function (el) {
        var key = el.getAttribute("data-key");
        var total = parseInt(el.getAttribute("data-total"), 10) || 1;
        var done = {};
        try { done = JSON.parse(localStorage.getItem(key) || "{}") || {}; } catch (e) {}
        var count = 0; for (var k in done) { if (done[k]) count++; }
        var bar = el.querySelector(".disc-prog-bar span");
        var num = el.querySelector(".disc-prog-num");
        if (bar) bar.style.width = (count / total * 100) + "%";
        if (num) num.textContent = count + "/" + total;
      });
    })();
  </script>
</Base>
